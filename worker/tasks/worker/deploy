#!/usr/bin/env bash
#MISE description="Deploy to Cloudflare Workers."
#MISE hide=true
#MISE dir="worker"
#MISE depends=["worker:build"]

#USAGE flag "--preview" default="false" help="Upload a new version without deploying it."
#USAGE flag "--dry-run" default="false" help="Build without uploading or deploying."

set -euo pipefail

# tag length is limited to 25 characters
short_sha=$(git rev-parse --short HEAD)
message=$(git log -1 --format=%s HEAD)
output_dir=$(mktemp --directory "${RUNNER_TEMP:-${TMPDIR:-/tmp}}/wrangler-output.XXXXXX")
export WRANGLER_OUTPUT_FILE_DIRECTORY=${output_dir}

cleanup() {
	rm --recursive --force -- "${output_dir}"
}
trap cleanup EXIT

wrangler_args=(--tag "${short_sha}" --message "${message}")
if [[ ${usage_dry_run} == 'true' ]]; then
	wrangler_args+=(--dry-run)
fi

find_wrangler_output() {
	local type=$1
	local files=()
	shopt -s nullglob
	files=("${output_dir}"/wrangler-output-*.json)
	shopt -u nullglob
	if ((${#files[@]} == 0)); then
		return 1
	fi
	jq --compact-output --slurp --arg type "${type}" \
		'map(select(.type == $type)) | first // empty' "${files[@]}"
}

append_output() {
	if [[ -n ${GITHUB_OUTPUT:-} ]]; then
		printf '%s\n' "$@" >>"${GITHUB_OUTPUT}"
	fi
}

append_summary() {
	if [[ -n ${GITHUB_STEP_SUMMARY:-} ]]; then
		printf '%s\n' "$@" >>"${GITHUB_STEP_SUMMARY}"
	fi
}

link() {
	local url=$1
	if [[ -n ${url} ]]; then
		printf '<%s>' "${url}"
	else
		printf '_Unavailable_'
	fi
}

if [[ ${usage_preview} == 'true' ]]; then
	preview_alias=${PREVIEW_ALIAS:-branch-${short_sha}}

	set -x
	bun run wrangler versions upload --preview-alias "${preview_alias}" "${wrangler_args[@]}"
	set +x

	if [[ ${usage_dry_run} == 'true' ]]; then
		exit 0
	fi

	upload=$(find_wrangler_output version-upload) || {
		echo "Unable to find Wrangler preview output" >&2
		exit 1
	}
	preview_url=$(jq --raw-output '.preview_url // empty' <<<"${upload}")
	preview_alias_url=$(jq --raw-output '.preview_alias_url // empty' <<<"${upload}")
	append_output "preview-url=${preview_url}" "preview-alias-url=${preview_alias_url}"
	append_summary \
		"### Cloudflare Workers Preview" \
		"" \
		"Branch alias: \`${preview_alias}\`" \
		"" \
		"| Name | URL |" \
		"| - | - |" \
		"| Version preview | $(link "${preview_url}") |" \
		"| Branch alias preview | $(link "${preview_alias_url}") |" \
		""
	exit 0
fi

set -x
bun run wrangler deploy "${wrangler_args[@]}"
set +x

if [[ ${usage_dry_run} == 'true' ]]; then
	exit 0
fi

deploy=$(find_wrangler_output deploy) || {
	echo "Unable to find Wrangler production deploy output" >&2
	exit 1
}
mapfile -t targets < <(jq --raw-output '.targets[]?' <<<"${deploy}")
summary=(
	"### Cloudflare Workers Production Deploy"
	""
	"| Target |"
	"| - |"
)
if ((${#targets[@]} > 0)); then
	for target in "${targets[@]}"; do
		summary+=("| <${target}> |")
	done
else
	summary+=("| _Unavailable_ |")
fi
summary+=("")
append_summary "${summary[@]}"
