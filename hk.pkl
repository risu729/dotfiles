amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

local const jsTsTypes = List("javascript", "typescript")
local const shellGlobs = List(
  "tasks/**",
  "worker/docker/entrypoint.sh",
  "worker/tasks/**",
  "wsl/home/.bashrc",
  "wsl/home/.config/mise/tasks/**",
  "wsl/home/.local/bin/**",
  "wsl/install.sh",
)

local const lintSteps = new Mapping<String, Step> {
  ["oxlint"] = (Builtins.ox_lint) {
    types = jsTsTypes
    check = "oxlint --no-error-on-unmatched-pattern --report-unused-disable-directives-severity error {{ files }}"
    fix = "oxlint --no-error-on-unmatched-pattern --report-unused-disable-directives-severity error --fix {{ files }}"
  }
  ["oxfmt"] {
    types = List("javascript", "typescript", "json", "markdown")
    check = "oxfmt --check {{ files }}"
    fix = "oxfmt {{ files }}"
  }
  ["actionlint"] = (Builtins.actionlint) {
    batch = false
    check = "actionlint -color {{ files }}"
    env {
      ["SHELLCHECK_OPTS"] = "--enable=all --exclude=SC2312"
    }
  }
  ["pinact"] = Builtins.pinact
  ["ghalint"] = (Builtins.ghalint_workflow) {
    depends = "pinact"
  }
  ["zizmor"] = (Builtins.zizmor) {
    check_diff = "zizmor --no-progress --pedantic {{ files }}"
    fix = "zizmor --no-progress --pedantic --fix {{ files }}"
  }
  ["taplo"] {
    types = List("toml")
    env {
      ["RUST_LOG"] = "warn"
    }
    check = "taplo lint {{ files }}"
  }
  ["taplo-format"] {
    types = List("toml")
    env {
      ["RUST_LOG"] = "warn"
    }
    check_diff = "taplo format --check --diff {{ files }}"
    fix = "taplo format {{ files }}"
  }
  ["markdownlint"] {
    types = List("markdown")
    check = "markdownlint-cli2 {{ files }}"
    fix = "markdownlint-cli2 --fix {{ files }}"
  }
  ["shfmt"] {
    glob = shellGlobs
    batch = false
    check_diff = "shfmt --diff --simplify {{ files }}"
    fix = "shfmt --write --simplify {{ files }}"
  }
  ["shellcheck"] {
    glob = shellGlobs
    batch = false
    check = "shellcheck --external-sources {{ files }}"
  }
  ["pwsh"] {
    glob = List("win/**/*.ps1", "win/**/*.psd1")
    check = "pwsh -Command 'Invoke-ScriptAnalyzer -Path win -Recurse -EnableExit -Settings win/PSScriptAnalyzerSettings.psd1'"
  }
  ["yamlfmt"] = (Builtins.yamlfmt) {
    types = List("yaml")
  }
  ["yamllint"] = (Builtins.yamllint) {
    types = List("yaml")
  }
  ["hadolint"] = (Builtins.hadolint) {
    check = "hadolint --failure-threshold none {{ files }}"
  }
  ["mise"] {
    glob = List("mise.toml", "tasks.toml", "tasks/**", "worker/tasks.toml", "worker/tasks/**")
    check = "mise fmt --check && mise task validate"
    fix = "mise fmt && mise task validate"
  }
  ["lychee"] = (Builtins.lychee) {
    check = "lychee --no-progress --verbose {{ files }}"
  }
  ["typos"] = Builtins.typos
  ["ignore-sync"] {
    glob = List(".gitignore-sync", "worker/.gitignore-sync")
    check = "ignore-sync . && ignore-sync worker && git diff --exit-code -- .gitignore worker/.gitignore"
    fix = "ignore-sync . && ignore-sync worker"
    stage = List(".gitignore", "worker/.gitignore")
    exclusive = true
  }
  ["jsonschema"] {
    types = List("json")
    check = "jschema-validator"
  }
  ["tsc:root"] {
    types = jsTsTypes
    check = "bun run tsc"
    profiles = List("!ci")
  }
  ["tsc:root:ci"] {
    types = jsTsTypes
    check = "bun run tsc --incremental false"
    profiles = List("ci")
  }
  ["worker:generate-types"] {
    check = "bun run wrangler types src/worker-configuration.d.ts"
    dir = "worker"
    hide = true
  }
  ["worker:tsc:base"] {
    types = jsTsTypes
    check = "bun run tsc --project tsconfig.base.json"
    dir = "worker"
    profiles = List("!ci")
  }
  ["worker:tsc:base:ci"] {
    types = jsTsTypes
    check = "bun run tsc --project tsconfig.base.json --incremental false"
    dir = "worker"
    profiles = List("ci")
  }
  ["worker:tsc:src"] {
    types = jsTsTypes
    check = "bun run tsc --project tsconfig.src.json"
    dir = "worker"
    depends = "worker:generate-types"
    profiles = List("!ci")
  }
  ["worker:tsc:src:ci"] {
    types = jsTsTypes
    check = "bun run tsc --project tsconfig.src.json --incremental false"
    dir = "worker"
    depends = "worker:generate-types"
    profiles = List("ci")
  }
  ["worker:tsc:test"] {
    types = jsTsTypes
    check = "bun run tsc --project tsconfig.test.json"
    dir = "worker"
    depends = "worker:generate-types"
    profiles = List("!ci")
  }
  ["worker:tsc:test:ci"] {
    types = jsTsTypes
    check = "bun run tsc --project tsconfig.test.json --incremental false"
    dir = "worker"
    depends = "worker:generate-types"
    profiles = List("ci")
  }
}

hooks {
  ["check"] {
    steps = lintSteps
  }
  ["fix"] {
    fix = true
    steps = lintSteps
  }
}
